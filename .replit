MIGRATIONS_PATH = "/home/runner/workspace/lib/db/migrations"
EXPO_TOKEN = "Cb1-gfSWt4DjbZsmFX4rE-3p4fD69IqQLNOXOE8M"
NGROK_AUTHTOKEN = "3Cu5SyGSIqgjCgP7kda5ZhlUsne_mNJNqdDtppe9SkA7g7fz"

[[ports]]
