{
  "expo": {
    "name": "FC Career Manager",
    "slug": "fc-career-manager-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fccareer",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0714"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fccareer.manager",
      "associatedDomains": ["applinks:fccareer.app", "applinks:www.fccareer.app"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B0714"
      },
      "package": "com.fccareer.manager",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "fccareer.app" },
            { "scheme": "https", "host": "www.fccareer.app" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [{ "scheme": "fccareer" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#8B5CF6",
          "sounds": ["./assets/sounds/notification.mp3"],
          "androidMode": "default",
          "androidCollapsedTitle": "FC Career Manager"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "046b20f2-ba31-42bb-a90b-1fa8be7bdfb4"
      }
    },
    "owner": "cauedds"
  }
}
